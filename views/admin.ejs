<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Colegiados</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: #eee; min-height: 100vh; }

    .login-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: #1a1a2e; display: flex; align-items: center; justify-content: center;
      z-index: 999;
    }
    .login-box {
      background: #16213e; padding: 40px; border-radius: 8px; width: 320px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }
    .login-box h2 { margin-bottom: 20px; color: #e94560; text-align: center; }
    .login-box input {
      width: 100%; padding: 10px; margin-bottom: 12px; border: 1px solid #333;
      border-radius: 4px; background: #0f3460; color: #eee; font-size: 14px;
    }
    .login-box button {
      width: 100%; padding: 10px; background: #e94560; color: white; border: none;
      border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 600;
    }
    .login-box button:hover { background: #c73650; }
    .login-error { color: #e94560; font-size: 12px; text-align: center; margin-top: 8px; display: none; }

    .admin-container { max-width: 1100px; margin: 0 auto; padding: 20px; display: none; }
    .admin-container.active { display: block; }

    .admin-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e94560;
    }
    .admin-header h1 { font-size: 20px; color: #e94560; }
    .btn-logout {
      background: #333; color: #ccc; border: 1px solid #555; padding: 6px 14px;
      border-radius: 4px; cursor: pointer; font-size: 12px;
    }

    .form-card {
      background: #16213e; padding: 20px; border-radius: 8px; margin-bottom: 20px;
    }
    .form-card h3 { margin-bottom: 15px; color: #e94560; font-size: 15px; }
    .form-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
    }
    .form-grid label { font-size: 11px; color: #aaa; display: block; margin-bottom: 3px; }
    .form-grid input, .form-grid select {
      width: 100%; padding: 7px; border: 1px solid #333; border-radius: 4px;
      background: #0f3460; color: #eee; font-size: 13px;
    }
    .btn-add {
      margin-top: 12px; padding: 8px 24px; background: #e94560; color: white;
      border: none; border-radius: 4px; cursor: pointer; font-weight: 600;
    }
    .btn-add:hover { background: #c73650; }

    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 12px; }
    th { background: #16213e; padding: 8px 6px; text-align: left; color: #e94560; white-space: nowrap; }
    td { padding: 6px; border-bottom: 1px solid #222; white-space: nowrap; }
    tr:hover { background: rgba(233,69,96,0.05); }

    .btn-edit, .btn-delete {
      padding: 3px 8px; border: none; border-radius: 3px;
      cursor: pointer; font-size: 11px; margin-right: 3px;
    }
    .btn-edit { background: #0f3460; color: #eee; }
    .btn-delete { background: #e94560; color: white; }

    .msg { padding: 8px 14px; border-radius: 4px; margin-bottom: 12px; font-size: 13px; display: none; }
    .msg.success { background: #1b5e20; color: #a5d6a7; display: block; }
    .msg.error { background: #b71c1c; color: #ef9a9a; display: block; }
  </style>
</head>
<body>

  <!-- Login -->
  <div class="login-overlay" id="login-overlay">
    <div class="login-box">
      <h2>Admin Panel</h2>
      <input type="text" id="login-user" placeholder="Usuario">
      <input type="password" id="login-pass" placeholder="Contrase&ntilde;a">
      <button onclick="doLogin()">Ingresar</button>
      <div class="login-error" id="login-error">Credenciales incorrectas</div>
    </div>
  </div>

  <!-- Admin -->
  <div class="admin-container" id="admin-container">
    <div class="admin-header">
      <h1>Colegiados - Panel Admin</h1>
      <button class="btn-logout" onclick="doLogout()">Cerrar Sesion</button>
    </div>

    <div id="msg-area"></div>

    <!-- Form -->
    <div class="form-card">
      <h3 id="form-title">Agregar Colegiado</h3>
      <div class="form-grid">
        <div>
          <label>Reg. CIP *</label>
          <input type="text" id="f-cip" placeholder="291951">
        </div>
        <div>
          <label>Primer Apellido *</label>
          <input type="text" id="f-papellido" placeholder="CARHUAMACA" style="text-transform:uppercase">
        </div>
        <div>
          <label>Segundo Apellido</label>
          <input type="text" id="f-sapellido" placeholder="PAYANO" style="text-transform:uppercase">
        </div>
        <div>
          <label>Nombres *</label>
          <input type="text" id="f-nombres" placeholder="FIDEL" style="text-transform:uppercase">
        </div>
        <div>
          <label>Especialidad</label>
          <input type="text" id="f-especialidad" placeholder="AMBIENTAL" style="text-transform:uppercase">
        </div>
        <div>
          <label>Capitulo</label>
          <input type="text" id="f-capitulo" placeholder="AMBIENTAL" style="text-transform:uppercase">
        </div>
        <div>
          <label>Sede</label>
          <input type="text" id="f-sede" placeholder="JUNIN" style="text-transform:uppercase">
        </div>
        <div>
          <label>Estado Registro</label>
          <select id="f-estado">
            <option value="ACTIVO">ACTIVO</option>
            <option value="INACTIVO">INACTIVO</option>
          </select>
        </div>
        <div>
          <label>Condicion</label>
          <select id="f-condicion">
            <option value="HABILITADO">HABILITADO</option>
            <option value="INHABILITADO">INHABILITADO</option>
          </select>
        </div>
        <div>
          <label>Nro Documento</label>
          <input type="text" id="f-nrodoc" placeholder="12345678">
        </div>
        <div>
          <label>Tipo Documento</label>
          <select id="f-tipodoc">
            <option value="4612">Reg. CIP</option>
            <option value="8">DNI</option>
            <option value="9">RUC</option>
          </select>
        </div>
        <div>
          <label>Tipo Colegiado</label>
          <select id="f-tipocol">
            <option value="5348">ORDINARIO O VITALICIO</option>
            <option value="5350">TEMPORAL</option>
          </select>
        </div>
        <div>
          <label>Fecha Incorporacion</label>
          <input type="text" id="f-fechainc" placeholder="29/09/2022">
        </div>
        <div>
          <label>Fecha Reconocimiento CIP</label>
          <input type="text" id="f-fecharec" placeholder="29/09/2022">
        </div>
        <div>
          <label>URL Foto (opcional)</label>
          <input type="text" id="f-foto" placeholder="https://...">
        </div>
      </div>
      <button class="btn-add" onclick="saveRecord()">Guardar</button>
      <button class="btn-add" id="btn-cancel" onclick="cancelEdit()" style="background:#555;display:none;">Cancelar</button>
    </div>

    <!-- Tabla -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>CIP</th>
            <th>Nombre Completo</th>
            <th>Especialidad</th>
            <th>Sede</th>
            <th>Estado</th>
            <th>Condicion</th>
            <th>Nro Doc</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>
  </div>

  <script>
    const API = '<%= apiUrl %>';
    let authHeader = '';
    let editingId = null;

    function doLogin() {
      const user = document.getElementById('login-user').value;
      const pass = document.getElementById('login-pass').value;
      authHeader = 'Basic ' + btoa(user + ':' + pass);

      fetch(`${API}/admin/colegiados`, { headers: { Authorization: authHeader } })
        .then(r => {
          if (r.status === 401 || r.status === 403) throw new Error('bad');
          return r.json();
        })
        .then(() => {
          document.getElementById('login-overlay').style.display = 'none';
          document.getElementById('admin-container').classList.add('active');
          loadRecords();
        })
        .catch(() => {
          document.getElementById('login-error').style.display = 'block';
        });
    }

    function doLogout() {
      authHeader = '';
      document.getElementById('login-overlay').style.display = 'flex';
      document.getElementById('admin-container').classList.remove('active');
    }

    document.getElementById('login-pass').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') doLogin();
    });

    function showMsg(text, type) {
      const el = document.getElementById('msg-area');
      el.innerHTML = `<div class="msg ${type}">${text}</div>`;
      setTimeout(() => el.innerHTML = '', 3000);
    }

    async function loadRecords() {
      try {
        const res = await fetch(`${API}/admin/colegiados`, { headers: { Authorization: authHeader } });
        const data = await res.json();
        document.getElementById('table-body').innerHTML = data.map(r => `
          <tr>
            <td>${r.id}</td>
            <td>${r.vRegCip}</td>
            <td>${r.vRazonSocial || ''}</td>
            <td>${r.vEspecialidad || ''}</td>
            <td>${r.vSede || ''}</td>
            <td>${r.vEstado || ''}</td>
            <td>${r.condicion || ''}</td>
            <td>${r.nro_documento || ''}</td>
            <td>
              <button class="btn-edit" onclick='startEdit(${JSON.stringify(r).replace(/'/g, "&#39;")})'>Editar</button>
              <button class="btn-delete" onclick="deleteRecord(${r.id})">Eliminar</button>
            </td>
          </tr>
        `).join('');
      } catch (e) {
        showMsg('Error cargando registros', 'error');
      }
    }

    async function saveRecord() {
      const body = {
        vRegCip: g('f-cip'),
        primer_apellido: g('f-papellido').toUpperCase(),
        segundo_apellido: g('f-sapellido').toUpperCase(),
        nombres: g('f-nombres').toUpperCase(),
        vEspecialidad: g('f-especialidad').toUpperCase(),
        capitulo: g('f-capitulo').toUpperCase(),
        vSede: g('f-sede').toUpperCase(),
        vEstado: g('f-estado'),
        condicion: g('f-condicion'),
        nro_documento: g('f-nrodoc'),
        tipo_documento: Number(g('f-tipodoc')),
        tipo_colegiado: Number(g('f-tipocol')),
        fecha_incorporacion: g('f-fechainc'),
        fecha_reconocimiento: g('f-fecharec'),
        foto_url: g('f-foto')
      };

      if (!body.vRegCip) return showMsg('CIP es obligatorio', 'error');

      const method = editingId ? 'PUT' : 'POST';
      const url = editingId ? `${API}/admin/colegiados/${editingId}` : `${API}/admin/colegiados`;

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', Authorization: authHeader },
          body: JSON.stringify(body)
        });
        if (res.ok) {
          showMsg(editingId ? 'Actualizado' : 'Creado', 'success');
          cancelEdit();
          clearForm();
          loadRecords();
        } else {
          const d = await res.json();
          showMsg(d.error || 'Error', 'error');
        }
      } catch (e) {
        showMsg('Error de conexion', 'error');
      }
    }

    function startEdit(r) {
      editingId = r.id;
      s('f-cip', r.vRegCip);
      s('f-papellido', r.primer_apellido);
      s('f-sapellido', r.segundo_apellido);
      s('f-nombres', r.nombres);
      s('f-especialidad', r.vEspecialidad);
      s('f-capitulo', r.capitulo);
      s('f-sede', r.vSede);
      s('f-estado', r.vEstado || 'ACTIVO');
      s('f-condicion', r.condicion || 'HABILITADO');
      s('f-nrodoc', r.nro_documento);
      s('f-tipodoc', r.tipo_documento || '4612');
      s('f-tipocol', r.tipo_colegiado || '5348');
      s('f-fechainc', r.fecha_incorporacion);
      s('f-fecharec', r.fecha_reconocimiento);
      s('f-foto', r.foto_url);
      document.getElementById('form-title').textContent = 'Editar #' + r.id;
      document.getElementById('btn-cancel').style.display = 'inline-block';
      window.scrollTo(0, 0);
    }

    function cancelEdit() {
      editingId = null;
      document.getElementById('form-title').textContent = 'Agregar Colegiado';
      document.getElementById('btn-cancel').style.display = 'none';
    }

    function clearForm() {
      ['f-cip','f-papellido','f-sapellido','f-nombres','f-especialidad','f-capitulo',
       'f-sede','f-nrodoc','f-fechainc','f-fecharec','f-foto'].forEach(id => {
        document.getElementById(id).value = '';
      });
      s('f-estado', 'ACTIVO');
      s('f-condicion', 'HABILITADO');
    }

    async function deleteRecord(id) {
      if (!confirm('Eliminar #' + id + '?')) return;
      try {
        const res = await fetch(`${API}/admin/colegiados/${id}`, {
          method: 'DELETE', headers: { Authorization: authHeader }
        });
        if (res.ok) { showMsg('Eliminado', 'success'); loadRecords(); }
      } catch (e) { showMsg('Error', 'error'); }
    }

    function g(id) { return (document.getElementById(id).value || '').trim(); }
    function s(id, v) { document.getElementById(id).value = v || ''; }
  </script>
</body>
</html>
